using namespace std;
using namespace std::chrono;

const int N = 1024;
const int BLOCK = 64;

// 1. Наивное умножение
void okak1(const float* A, const float* B, float* C, int n)
{
    for (int i = 0; i < n; ++i)
    {
        for (int j = 0; j < n; ++j)
        {
            float sum = 0.0f;

            for (int k = 0; k < n; ++k)
            {
                sum += A[i * n + k] * B[k * n + j];
            }

            C[i * n + j] = sum;
        }
    }
}
// 2. MKL
void okak2(const float* A, const float* B, float* C, int n)
{
    cblas_sgemm(
        CblasRowMajor,
        CblasNoTrans,
        CblasNoTrans,
        n,
        n,
        n,
        1.0f,
        A,
        n,
        B,
        n,
        0.0f,
        C,
        n
    );
}
// 3. Оптимизированное блочное умножение
void okak3(const float* A, const float* B, float* C, int n)
{
    // Обнуление
#pragma omp parallel for
    for (int i = 0; i < n * n; ++i)
    {
        C[i] = 0.0f;
    }
    // BLOCKING + OPENMP
#pragma omp parallel for collapse(2) schedule(dynamic)
    for (int ii = 0; ii < n; ii += BLOCK)
    {
        for (int kk = 0; kk < n; kk += BLOCK)
        {
            for (int jj = 0; jj < n; jj += BLOCK)
            {
                int i_max = min(ii + BLOCK, n);
                int k_max = min(kk + BLOCK, n);
                int j_max = min(jj + BLOCK, n);

                for (int i = ii; i < i_max; ++i)
                {
                    for (int k = kk; k < k_max; ++k)
                    {
                        float a = A[i * n + k];

#pragma omp simd
                        for (int j = jj; j < j_max; ++j)
                        {
                            C[i * n + j] += a * B[k * n + j];
                        }
                    }
                }
            }
        }
    }
}
// Проверка корректности

bool check_correctness(
    const vector<float>& ref,
    const vector<float>& test,
    int n)
{
    const float eps = 1e-2f;
    for (int i = 0; i < n * n; ++i)
    {
        if (fabs(ref[i] - test[i]) > eps)
        {
            cout << "Ошибка в элементе "
                << i
                << " : "
                << ref[i]
                << " vs "
                << test[i]
                << endl;

            return false;
        }
    }

    return true;
}
// MFLOPS
double calculate_mflops(int n, double time_seconds)
{
    double ops = 2.0 * n * n * n;

    return (ops / time_seconds) * 1e-6;
}
