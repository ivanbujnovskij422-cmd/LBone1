    auto end1 = high_resolution_clock::now();
    double time1 =
        duration<double>(end1 - start1).count();
    double mflops1 =
        calculate_mflops(N, time1);
    // 2. MKL

    cout << "MKL..." << endl;
    auto start2 = high_resolution_clock::now();
    okak2(A.data(), B.data(), C2.data(), N);
    auto end2 = high_resolution_clock::now();
    double time2 =
