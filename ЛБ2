const int N = 1024;

// 1-й вариант: Классическая формула из линейной алгебры (наивный алгоритм i-j-k)
void multiply_naive(const float* A, const float* B, float* C, int n) {
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            float sum = 0.0f;
            for (int k = 0; k < n; ++k) {
                sum += A[i * n + k] * B[k * n + j];
            }
            C[i * n + j] = sum;
        }
    }
}

// 2-й вариант: Использование функции cblas_sgemm из Intel MKL
void multiply_mkl(const float* A, const float* B, float* C, int n) {
    cblas_sgemm(CblasRowMajor, CblasNoTrans, CblasNoTrans,
                n, n, n, 1.0f, A, n, B, n, 0.0f, C, n);
}

// 3-й вариант: Оптимизированный алгоритм (изменение порядка циклов на i-k-j + OpenMP)
// Порядок i-k-j делает доступ к памяти последовательным (cache-friendly).
// OpenMP распараллеливает вычисления на все ядра процессора.
void multiply_optimized(const float* A, const float* B, float* C, int n) {
    // Инициализация нулями
    #pragma omp parallel for
    for (int i = 0; i < n * n; ++i) {
        C[i] = 0.0f;
    }

    #pragma omp parallel for
    for (int i = 0; i < n; ++i) {
        for (int k = 0; k < n; ++k) {
            float a_ik = A[i * n + k];
            #pragma omp simd
            for (int j = 0; j < n; ++j) {
                C[i * n + j] += a_ik * B[k * n + j];
            }
        }
    }
}

// Функция для вычисления MFlops
double calculate_mflops(int n, double time_seconds) {
    double c = 2.0 * n * n * n; // Оценка сложности c = 2*n^3
    return (c / time_seconds) * 1e-6;
}

