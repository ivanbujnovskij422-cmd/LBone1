    // 3. Оптимизированный

    cout << "Оптимизированный..." << endl;
    auto start3 = high_resolution_clock::now();
    okak3(A.data(), B.data(), C3.data(), N);
    auto end3 = high_resolution_clock::now();
    double time3 =
        duration<double>(end3 - start3).count();
    double mflops3 =
