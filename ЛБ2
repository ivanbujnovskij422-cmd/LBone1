Так как матрицы огромные , они гарантированно не помещаются в L1/L2/L3 кэш процессора целиком. Поэтому ключевую роль здесь будет играть именно локальность данных.
Разберу и напишем реализацию для всех трех вариантов на C++.
Выделение памяти и генерация
Для матриц такого размера выделять память на стеке нельзя — произойдет переполнение (stack overflow) => использую динамическую память. Чтобы процессор мог эффективно читать данные, лучше всего развернуть двумерную матрицу в одномерный массив (строка за строкой).

#include <iostream>
#include <vector>
#include <chrono>
#include <random>
#include <cmath>

// Для Intel MKL / BLAS
#include <mkl.h> 

const int N = 4096;

// Функция для генерации случайной матрицы
void generate_matrix(float* mat, int size) {
    std::random_device rd;
    std::mt_device eng(rd());
    std::uniform_real_distribution<float> distr(0.0f, 1.0f);
    
    for (int i = 0; i < size * size; ++i) {
        mat[i] = distr(eng);
    }
}
Вариант 1:
Классический алгоритм со сложностью O(n^3) по стандартной формуле:C_ij = ∑_(k=1)^n A_ik · Bkj
В трех вложенных циклах i, j, k мы идем по строкам матрицы A (эффективно для кэша), но по столбцам матрицы B. Проход по столбцам заставляет процессор прыгать по памяти с огромным шагом (4096 * 4 байта), что вызывает постоянные промахи мимо кэша (cache misses). Это будет самый медленный вариант.

void multiply_naive(const float* A, const float* B, float* C, int n) {
    // Инициализируем матрицу C нулями
    std::fill(C, C + n * n, 0.0f);

    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            for (int k = 0; k < n; ++k) {
                C[i * n + j] += A[i * n + k] * B[k * n + j];
            }
        }
    }
}
Вариант 2: 
Функция cblas_sgemm из библиотеки Intel MKL оптимизирована под конкретную архитектуру вашего процессора с использованием векторных инструкций (AVX-2 / AVX-512) и блочного разделения памяти на уровне ассемблера. Это наш , так сказать "эталон" скорости.

void multiply_blas(const float* A, const float* B, float* C, int n) {
    // cblas_sgemm выполняет операцию: C = alpha*A*B + beta*C
    cblas_sgemm(CblasRowMajor, CblasNoTrans, CblasNoTrans, 
                n, n, n, 
                1.0f,  // alpha
                A, n, 
                B, n, 
                0.0f,  // beta
                C, n);
}
Вариант 3: 
Чтобы достичь производительности «не ниже 30% от Intel MKL»,нужно решить проблему промахов кэша и задействовать все ядра процессора.

я сделал так:
1. Перестановка циклов (i, k, j) вместо (i, j, k): Если поменять местами внутренние циклы, то в самом глубоком цикле буду двигаться по строке матрицы B и по строке матрицы C. Это обеспечивает последовательный доступ к памяти (Spatial Locality) и позволяет компилятору автоматически применить векторные инструкции (SIMD).
2. Параллелизм через OpenMP: Разделю внешние итерации между ядрами процессора с помощью директивы #pragma omp parallel for.
`cpp
void multiply_optimized(const float* A, const float* B, float* C, int n) {
std::fill(C, C + n * n, 0.0f);

// Распараллеливаем внешний цикл по строкам
    #pragma omp parallel for schedule(static)
        for (int i = 0; i < n; ++i) {
            for (int k = 0; k < n; ++k) {
                float r = A[i * n + k]; // Фиксируем элемент, чтобы не читать его каждый раз
                    for (int j = 0; j < n; ++j) {
                        C[i * n + j] += r * B[k * n + j];
                    }
                }
             }
         }

*Примечание: Если этого окажется недостаточно, можно применить полноценное разбиение на блоки (Tiling/Blocking), например, блоками 64 * 64, чтобы данные подматрицы целиком помещались в L1-кэш.
## Главная функция (Метрики и Сравнение)
Расчет по формулам из задания:
 * Число операций: c = 2n^3
 * Производительность в MFlops: P = \frac{c}{t \cdot 10^6}
cpp
int main() {
    // Выделяем память под матрицы в "выравниваемом" пуле для лучшей производительности
    float* A = (float*)mkl_malloc(N * N * sizeof(float), 64);
    float* B = (float*)mkl_malloc(N * N * sizeof(float), 64);
    float* C = (float*)mkl_malloc(N * N * sizeof(float), 64);

    std::cout << "Генерация матриц размера " << N << "x" << N << "..." << std::endl;
    generate_matrix(A, N);
    generate_matrix(B, N);

    double c_ops = 2.0 * std::pow(N, 3); // Число операций

    auto run_benchmark = [&](const std::string& name, void (*func)(const float*, const float*, float*, int)) {
        std::cout << "\nЗапуск: " << name << "..." << std::endl;
        
        auto start = std::chrono::high_resolution_clock::now();
        func(A, B, C, N);
        auto end = std::chrono::high_resolution_clock::now();
        
        std::chrono::duration<double> duration = end - start;
        double seconds = duration.count();
        double mflops = (c_ops / seconds) / 1e6;

        std::cout << "Время выполнения: " << seconds << " сек." << std::endl;
        std::cout << "Производительность: " << mflops << " MFlops" << std::endl;
        return mflops;
    };

    // ВАЖНО: Наивный алгоритм на таком размере может выполняться несколько МИНУТ.
    // Если нужно просто сдать, можно уменьшить размер N для теста наивного, 
    // либо запастись терпением.
    double mflops_naive = run_benchmark("1. Наивный алгоритм (i, j, k)", multiply_naive);
    double mflops_blas  = run_benchmark("2. Intel MKL (cblas_sgemm)", multiply_blas);
    double mflops_opt   = run_benchmark("3. Оптимизированный (i, k, j + OpenMP)", multiply_optimized);

    // Анализ результатов
    std::cout << "\n--- Сравнение и Анализ ---" << std::endl;
    std::cout << "Эффективность оптимизированного алгоритма относительно MKL: " 
              << (mflops_opt / mflops_blas) * 100.0 << "%" << std::endl;
    
    if ((mflops_opt / mflops_blas) >= 0.30) {
        std::cout << "Успех! Требование (не ниже 30% от Intel MKL) выполнено." << std::endl;
    } else {
        std::cout << "Внимание: Производительность ниже 30%. Требуется дополнительная блочная оптимизация." << std::endl;
    }VV

    // Освобождение памяти
    mkl_free(A);
    mkl_free(B);
    mkl_free(C);

    return 0;
}

### Как компилировать:
Для сборки программы понадобятся установленный **Intel OneAPI MKL**  и включенный флаг OpenMP. Пример команды для компиляции через g++:
bash
g++ -O3 -fopenmp main.cpp -lmkl_rt -o matrix_perf

